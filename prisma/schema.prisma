generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// USER SYSTEM
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String    // To be hashed with bcrypt
  role          Role      @default(EDITOR)
  credits       Int       @default(100) // Content generation credit balance
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  contents      Content[]
  wpCredentials WPCredential[]
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

// WORDPRESS CREDENTIALS (Isolated per user)
model WPCredential {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  siteUrl     String   // e.g., https://example.com
  wpUsername  String
  appPassword String   // To be encrypted with AES-256 before DB storage!
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, siteUrl])
}

// CONTENT MANAGEMENT
model Content {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title           String?
  targetKeyword   String
  bodyText        String?  @db.Text
  
  language        String   @default("en-US")
  aiModel         String   @default("claude-3-opus")
  
  // Content Configuration Fields
  contentType     String   @default("blog-post")
  writingGoal     String   @default("teaching")
  contentDepth    String   @default("beginner")
  targetWordCount Int      @default(2000)
  
  metaTitle       String?
  metaDescription String?
  
  status          ContentStatus @default(DRAFT)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum ContentStatus {
  DRAFT
  GENERATING
  COMPLETED
  PUBLISHED_TO_WP
}

// MULTILINGUAL (i18n) UI TRANSLATIONS
model Translation {
  id        String   @id @default(cuid())
  langCode  String   // e.g., 'en-US', 'es-ES'
  key       String   // e.g., 'btn_new_content'
  value     String   // e.g., 'New Content'
  
  @@unique([langCode, key])
}

// OTP AND VERIFICATION TOKENS
model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   // 6-digit OTP code
  expires   DateTime // 10-minute expiration time
  
  @@unique([email, token])
}